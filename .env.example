# Firebase — pick ONE method:
# Local file:
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# Cloud (Render/Railway): paste full JSON as one env var, leave GOOGLE_APPLICATION_CREDENTIALS unset
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=lifestudio-abf4b

# baileys (recommended) | webjs
WHATSAPP_PROVIDER=baileys
BAILEYS_AUTH_PATH=.baileys_auth
WWEBJS_DATA_PATH=.wwebjs_auth

# Public app URL (photographer mission links)
APP_URL=https://lifestudio-abf4b.web.app

# Express API (React dashboard polls this)
PORT=8080
BOT_API_KEY=change-me-to-a-long-random-secret

# Studio owner WhatsApp (international format, no +) e.g. 218926128650
# Comma-separated boss phones for booking alerts (Libya format, no +)
BOSS_PHONES=218926128650
OWNER_PHONE=218926128650

# Bank transfer (shown when client picks تحويل)
BANK_ACCOUNT_NAME=لايف استوديو
BANK_ACCOUNT_NUMBER=
BANK_IBAN=
BANK_IBAN_2=
BANK_NAME=مصرف ليبيا المركزي
BANK_TRANSFER_NOTE=يرجى إرسال صورة إيصال التحويل بعد الدفع

# Session defaults
DEFAULT_SESSION_DURATION_MINUTES=120
WORK_START_HOUR=9
WORK_END_HOUR=21
SLOT_INTERVAL_MINUTES=60

# Pricing (can also be overridden in Firestore bot_config/packages)
DEFAULT_PACKAGE_PRICE=1500
DEFAULT_DEPOSIT_PERCENT=30

# Ollama AI agent — use Cloud (no local install) OR any remote Ollama host
# Cloud: create key at https://ollama.com/settings/keys
OLLAMA_ENABLED=true
OLLAMA_API_KEY=
# Leave empty to auto-use https://ollama.com when API key is set
# OLLAMA_BASE_URL=https://ollama.com
# Cloud default model (override if you prefer another from ollama.com/library)
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_TEMPERATURE=0.65
OLLAMA_TIMEOUT_MS=90000
